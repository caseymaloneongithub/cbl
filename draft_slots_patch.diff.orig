--- /mnt/data/cbl-orig/cbl-main/server/routes.ts	2026-02-13 00:45:21.000000000 +0000
+++ /mnt/data/cbl-main/server/routes.ts	2026-02-13 22:40:28.250714467 +0000
@@ -4801,6 +4801,21 @@
         return res.status(400).json({ message: "Draft order must be set before starting" });
       }
 
+      const rounds = await storage.getDraftRounds(id);
+      if (rounds.length === 0) {
+        return res.status(400).json({ message: "Draft rounds must be configured before starting" });
+      }
+      // Ensure every round has an explicit per-round order (no snaking).
+      for (const r of rounds) {
+        const roundOrder = await storage.getDraftOrder(id, r.roundNumber);
+        if (roundOrder.length === 0) {
+          return res.status(400).json({ message: `Draft order must be set for round ${r.roundNumber} before starting` });
+        }
+      }
+
+      // Generate pick slots for all rounds up front (supports missed picks).
+      await storage.createDraftPickSlotsForAllRounds(id);
+
       const updated = await storage.updateDraft(id, {
         status: "active",
         currentRound: 1,
@@ -5001,7 +5016,14 @@
